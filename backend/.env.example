# Copy this file to .env and fill in your values
# Never commit the actual .env file to git

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/url_shortener"

# JWT secret — use a long random string in production
JWT_SECRET="replace_with_a_long_random_secret"

# How long JWT tokens stay valid
JWT_EXPIRES_IN="7d"

# Server port
PORT=5000

# The base URL of your backend (used to build short URLs)
# Local:      http://localhost:5000
# Production: https://your-service.onrender.com
BASE_URL="http://localhost:5000"

# Frontend origin (for CORS)
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL="http://localhost:5173"
